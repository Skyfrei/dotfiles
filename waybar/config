{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-right": ["cpu", "memory", "temperature", "disk", "clock"],

    "cpu": {
        "format": " {usage}%",
        "tooltip": false
    },
    "disk": {
        "path": "/home",
        "format": "󰋊 {percentage_used}%"
    },
    "memory": {
      "interval": 30,
      "format": "󰍛 {}%",
      "max-length": 10
    },
    "temperature": {
        "critical-threshold": 80,
        "format": " {temperatureC}°C"
    },
    "clock": {
        "format": "{:%d %B  %H:%M}"
    }
}
